# Local-preview env template.
# Copy to .env.local (gitignored) and fill in real values:
#   cp env.example .env.local
#
# Expo SDK 54 auto-loads .env.local at start; EXPO_PUBLIC_* vars are
# inlined into the JS bundle at build time. lib/env.ts reads these.

# Backend API base — defaults to https://wondrlink-chat.vercel.app
# when not set. Override for local preview if needed.
# EXPO_PUBLIC_API_BASE=https://wondrlink-chat.vercel.app

# Supabase credentials — REQUIRED for login / signup to work.
# Find these at:
#   Supabase dashboard → Project Settings → API → Project URL + anon public key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — Sentry crash reporting (leave blank if you don't have a DSN)
# EXPO_PUBLIC_SENTRY_DSN=
